<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top">
  <div class="container">

    <!-- Dynamic Logo Redirect -->
    <%
      let logoLink = "/";
      if (user) {
        logoLink = user.role === "student"
          ? "/student/dashboard?section=jobs"
          : "/recruiter/dashboard";
      }
    %>

    <a class="navbar-brand d-flex align-items-center fw-bold text-primary"
       href="<%= logoLink %>">
        <i class="bi bi-lightning-charge-fill me-2" style="font-size:1.4rem;"></i>
        SkillBridge
    </a>

    <div class="ms-auto">
      <% if(!user) { %>
        <a href="/login" class="btn btn-outline-primary me-2">Login</a>
        <a href="/register" class="btn btn-primary">Register</a>
      <% } else { %>

        <% if(user.role === "student") { %>
            <a href="/student/dashboard?section=profile"
               class="btn btn-primary me-2">
                Profile
            </a>
        <% } else { %>
            <a href="/recruiter/company-profile"
               class="btn btn-primary me-2">
                Company Profile
            </a>
        <% } %>

        <a href="/logout" class="btn btn-outline-danger">Logout</a>
      <% } %>
    </div>

  </div>
</nav>

<div style="margin-top:80px;"></div>