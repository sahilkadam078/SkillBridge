<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top">
  <div class="container">

    <!-- Dynamic Logo Redirect -->
    <% if (user) { %>
        <% if (user.role === "student") { %>
            <a class="navbar-brand fw-bold text-primary" href="/student/dashboard">
                SkillBridge
            </a>
        <% } else { %>
            <a class="navbar-brand fw-bold text-primary" href="/recruiter/dashboard">
                SkillBridge
            </a>
        <% } %>
    <% } else { %>
        <a class="navbar-brand fw-bold text-primary" href="/">
            SkillBridge
        </a>
    <% } %>

    <div class="ms-auto">
      <% if(!user) { %>
        <a href="/login" class="btn btn-outline-primary me-2">Login</a>
        <a href="/register" class="btn btn-primary">Register</a>
      <% } else { %>

        <% if(user.role === "student") { %>
            <!-- Open Profile Section Inside Dashboard -->
            <a href="/student/dashboard?section=profile" class="btn btn-primary me-2">
                Profile
            </a>
        <% } else { %>
            <a href="/recruiter/dashboard" class="btn btn-primary me-2">
                Dashboard
            </a>
        <% } %>

        <a href="/logout" class="btn btn-outline-danger">Logout</a>
      <% } %>
    </div>
  </div>
</nav>

<div style="margin-top:80px;"></div>