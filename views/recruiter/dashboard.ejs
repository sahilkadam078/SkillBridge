<div class="container-fluid" style="min-height:85vh;">
  <div class="row">

    <!-- LEFT SIDE -->
    <div class="col-md-3 bg-light border-end p-4">

      <h5 class="fw-bold mb-4">Recruiter Panel</h5>

      <a href="/recruiter/dashboard?section=add"
        class="nav-link mb-2 <%= section === 'add' ? 'text-primary fw-bold' : 'text-dark' %>">
        Add Internship
      </a>

      <a href="/recruiter/dashboard?section=my"
        class="nav-link mb-2 <%= section === 'my' ? 'text-primary fw-bold' : 'text-dark' %>">
        My Internships
      </a>

      <a href="/recruiter/dashboard?section=applications"
        class="nav-link mb-2 <%= section === 'applications' ? 'text-primary fw-bold' : 'text-dark' %>">
        All Applications
      </a>

    </div>


    <!-- RIGHT SIDE -->
    <div class="col-md-9 p-5">

      <!-- ADD INTERNSHIP -->
      <% if(section==="add" ) { %>

        <h2 class="mb-4 fw-semibold">Add Internship</h2>

        <div class="card shadow-sm border-0">
          <div class="card-body">

            <form method="POST" action="/recruiter/add">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="mb-3">
                <label class="form-label">Role</label>
                <input type="text" name="title" class="form-control" placeholder="e.g. MERN Stack Developer" required>
              </div>

              <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="3"></textarea>
              </div>

              <div class="mb-3">
                <label class="form-label">Required Skills</label>
                <input type="text" name="required_skills" class="form-control"
                  placeholder="HTML, CSS, JavaScript, React">
              </div>

              <div class="mb-3">
                <label class="form-label">Minimum Experience</label>
                <input type="text" name="min_experience" class="form-control" placeholder="Fresher / 1 year">
              </div>

              <div class="mb-3">
                <label class="form-label">Visibility</label>
                <select name="visibility" class="form-select">
                  <option value="active" selected>Active</option>
                  <option value="inactive">Inactive</option>
                </select>
              </div>

              <button class="btn btn-primary">
                Add Internship
              </button>

            </form>

          </div>
        </div>

        <% } %>



          <!-- MY INTERNSHIPS -->
          <% if(section==="my" ) { %>

            <h2 class="mb-4 fw-semibold">My Internships</h2>

            <% if(internships.length===0) { %>

              <p class="text-muted">No internships added yet.</p>

              <% } else { %>

                <% internships.forEach(job=> { %>

                  <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body">

                      <h5 class="fw-semibold">
                        <%= job.title %>
                      </h5>

                      <p class="text-muted small mb-2">
                        <%= job.description %>
                      </p>

                      <p class="mb-1">
                        <strong>Skills:</strong>
                        <%= job.required_skills %>
                      </p>

                      <p class="mb-2">
                        <strong>Experience:</strong>
                        <%= job.min_experience || "Fresher" %>
                      </p>

                      <span class="badge bg-<%= (job.visibility || 'inactive') === 'active' ? 'success' : 'secondary' %>">
                        <%= job.visibility || "inactive" %>
                      </span>

                      <div class="mt-3">

                        <a href="/recruiter/applicants/<%= job.id %>" class="btn btn-outline-primary btn-sm">
                          View Applicants
                        </a>

                        <a href="/recruiter/edit/<%= job.id %>" class="btn btn-outline-dark btn-sm">
                          Edit
                        </a>

                        <form method="POST" action="/recruiter/toggle/<%= job.id %>" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                          <button class="btn btn-outline-warning btn-sm">
                            <%= job.visibility==='active' ? 'Deactivate' : 'Activate' %>
                          </button>

                        </form>

                      </div>

                    </div>
                  </div>

                  <% }) %>

                    <% } %>

                      <% } %>



                        <!-- ALL APPLICATIONS -->
                        <% if(section==="applications" ) { %>

                          <h2 class="mb-4 fw-semibold">All Applications</h2>

                          <!-- FILTER -->
                          <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body">

                              <form method="GET" action="/recruiter/dashboard">

                                <input type="hidden" name="section" value="applications">

                                <div class="row align-items-end">

                                  <div class="col-md-4">
                                    <label class="form-label">Filter by Role</label>

                                    <select name="role" class="form-select">

                                      <option value="">All Roles</option>

                                      <% roles.forEach(role=> { %>

                                        <option value="<%= role.id %>" <%=(typeof selectedRole !=='undefined' &&
                                          selectedRole==role.id) ? "selected" : "" %>>
                                          <%= role.title %>
                                        </option>

                                        <% }) %>

                                    </select>
                                  </div>

                                  <div class="col-md-2">
                                    <button class="btn btn-primary">Search</button>
                                  </div>

                                </div>

                              </form>

                            </div>
                          </div>


                          <!-- APPLICATION TABLE -->
                          <div class="card shadow-sm border-0">
                            <div class="card-body">

                              <table class="table table-hover">

                                <thead>
                                  <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Experience</th>
                                    <th>Status</th>
                                  </tr>
                                </thead>

                                <tbody>

                                  <% if(applications.length===0) { %>

                                    <tr>
                                      <td colspan="5" class="text-center text-muted">
                                        No applications found
                                      </td>
                                    </tr>

                                    <% } else { %>

                                      <% applications.forEach(app=> { %>

                                        <tr>

                                          <td>
                                            <%= app.name %>
                                          </td>

                                          <td>
                                            <%= app.email %>
                                          </td>

                                          <td>
                                            <%= app.title %>
                                          </td>

                                          <td>
                                            <%= app.skills || "Fresher" %>
                                          </td>

                                          <td>
                                            <span class="badge
                <%= app.status === 'approved' ? 'bg-success' :
                    app.status === 'cancelled' ? 'bg-danger' :
                    'bg-secondary' %>">
                                              <%= app.status %>
                                            </span>
                                          </td>

                                        </tr>

                                        <% }) %>

                                          <% } %>

                                </tbody>

                              </table>

                            </div>
                          </div>

                          <% } %>

    </div>

  </div>
</div>
