<section class="hero text-center d-flex align-items-center">
    <div class="container">

        <h1 class="display-4 fw-bold fade-in">
            Connecting Skills to Opportunities
        </h1>

        <p class="lead mt-3 fade-in-delay">
            Smart internship matching platform for students and recruiters.
        </p>

        <div class="mt-4 fade-in-delay-2">
            <a href="/register" class="btn btn-primary btn-lg me-2">
                Get Started
            </a>

            <a href="/login" class="btn btn-outline-light btn-lg">
                Login
            </a>
        </div>

    </div>
</section>



<!-- INTERNSHIPS SECTION -->
<section class="py-5 bg-light">

<div class="container">

<h2 class="text-center mb-5 fw-bold">
Latest Internships
</h2>

<div class="row">

<% internships.forEach(job => { %>

<div class="col-lg-4 col-md-6 mb-4">

<div class="card shadow-sm border-0 h-100">

<div class="card-body">

<h5 class="fw-semibold">
<%= job.title %>
</h5>

<p class="text-muted small mb-2">
<%= job.description %>
</p>

<p class="mb-1">
<strong>Skills:</strong>
<%= job.required_skills %>
</p>

<p class="mb-3">
<strong>Experience:</strong>
<%= job.min_experience || "Fresher" %>
</p>

<% if(user) { %>

<form method="POST" action="/student/apply/<%= job.id %>">
<input type="hidden" name="_csrf" value="<%= csrfToken %>">
<button class="btn btn-primary btn-sm">
Apply
</button>
</form>

<% } else { %>

<a href="/login" class="btn btn-outline-primary btn-sm">
Apply
</a>

<% } %>

</div>

</div>

</div>

<% }) %>

</div>

</div>

</section>
